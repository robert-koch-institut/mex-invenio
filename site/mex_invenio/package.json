{
    "dependencies": {
        "i18next": "^25.6.2",
        "i18next-browser-languagedetector": "^8.2.0",
        "i18next-conv": "^16.0.0",
        "i18next-scanner": "^4.6.0",
        "react-i18next": "^16.3.1",
        "semantic-ui-css": "^2.5.0",
        "semantic-ui-react": "^2.1.5"
    },
    "scripts": {
        "convert-po": "npm run convert-po-en && npm run convert-po-de",
        "convert-po-de": "i18next-conv -l de -s ${INVENIO_INSTANCE_PATH:-../../}/translations/de/LC_MESSAGES/messages.po -t ./assets/semantic-ui/js/mex_invenio/locales/de/translations.json",
        "convert-po-en": "i18next-conv -l en -s ${INVENIO_INSTANCE_PATH:-../../}/translations/en/LC_MESSAGES/messages.po -t ./assets/semantic-ui/js/mex_invenio/locales/en/translations.json",
        "extract-messages": "i18next-scanner --config i18next-scanner.config.js './assets/semantic-ui/js/mex_invenio/**/*.js' '../../static/js/**/*.js'"
    }
}
