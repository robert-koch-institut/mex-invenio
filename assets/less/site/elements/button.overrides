.ui.button {
    overflow: hidden;
    text-overflow: ellipsis;
    &.link-like {
        background-color: transparent;
        padding: .5rem 0;
        font-weight: normal;
        color: @primaryColor;
        text-align: left;
        &:hover {
            background-color: transparent;
            padding: .5rem 0;
            font-weight: normal;
            color: #32008c;
            text-decoration: underline;
        }
    }
}
